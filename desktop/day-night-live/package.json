{
  "name": "day-night-live-desktop",
  "version": "1.1.0",
  "private": true,
  "description": "Live Windows desktop shell for the complete DAY NIGHT platform.",
  "author": "DAY NIGHT DELIVERY SERVICES",
  "license": "UNLICENSED",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.daynight.delivery.admin",
    "productName": "DAY NIGHT",
    "asar": true,
    "files": [
      "main.cjs",
      "preload.cjs",
      "offline.html",
      "build/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "DAY-NIGHT-Live-Setup-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DAY NIGHT",
      "uninstallDisplayName": "DAY NIGHT",
      "deleteAppDataOnUninstall": false
    }
  }
}
