dist/
build/
.next/
.nuxt/
public/dist/
*.min.js
*.min.css

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.nox/
*.so
*.egg-info/
.eggs/
mypy_cache/
.pytest_cache/
.hypothesis/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
jspm_packages/
*.js.map
*.mjs.map
*.cjs.map
*.tsbuildinfo
.nyc_output/
coverage/
.nyc_output/
istanbul/
.lintcache/
.commitlint.cache
.eslintcache
.node_repl_history
*.tgz

# TypeScript
*.tsbuildinfo
*.bak

# Compiled JavaScript
lib/
es/
dist/
tmp/
temp/

# Next.js
.next/
out/
build/

# React
*.hot-update.json
*.hot-update.js

# Bundler cache (varying by system environment)
.cache/
.svelte-kit/
.svelte/
.craft/
.vercel/
.now/
netlify/
```